# Path to your local code directory. This will be mounted into the container
# at the same path so file references are identical inside and outside Docker.
CODE_PATH=/Users/yourname/Documents/code

# Host port that maps to SSH inside the container (default: 2222)
# SSH_PORT=2222

# Project/container name — override to run multiple instances side by side
# COMPOSE_PROJECT_NAME=claude-dev

# SSH public keys to allow into the container (space-separated or newline-separated).
# Add one key per line within the double quotes.
SSH_AUTHORIZED_KEYS="ssh-rsa AAAA...your_key_here... user@host"
